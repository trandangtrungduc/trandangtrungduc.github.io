=t+"px",o.style.left=e.offsetWidth-o.offsetWidth/2+"px"}var o,l,a,c=0;l=e.offsetWidth,a=e.offsetHeight,e.style.width=l/2+"px",(o=document.createElement("DIV")).setAttribute("class","img-comp-slider"),e.parentElement.insertBefore(o,e),o.style.top=a/2-o.offsetHeight/2+"px",o.style.left=l/2-o.offsetWidth/2+"px",o.addEventListener("mousedown",t),window.addEventListener("mouseup",n),o.addEventListener("touchstart",t),window.addEventListener("touchend",n)}var t,n;for(t=document.getElementsByClassName("img-comp-overlay"),n=0;n<t.length;n++)e(t[n])}let slideIndex=1;showSlides(slideIndex),initComparisons();</script>]]></content><author><name></name></author><category term="paper"/><category term="paper"/><summary type="html"><![CDATA[visualization of 3D point cloud instance segmentation]]></summary></entry><entry><title type="html">NeuralNetwork Application for Mobile Robot</title><link href="https://trandangtrungduc.github.io/blog/2021/mobile-robot/" rel="alternate" type="text/html" title="NeuralNetwork Application for Mobile Robot"/><published>2021-09-07T00:00:00+00:00</published><updated>2021-09-07T00:00:00+00:00</updated><id>https://trandangtrungduc.github.io/blog/2021/mobile-robot</id><content type="html" xml:base="https://trandangtrungduc.github.io/blog/2021/mobile-robot/"><![CDATA[<p>Real mobile robot model running along the black line.</p> <div class="row mt-3"> <div class="col-sm mt-3 mt-md-0"> <figure> <video src="/assets/video/map_number_8.mp4" class="img-fluid rounded z-depth-1" width="auto" height="auto" autoplay="" controls=""/> </figure> </div> <div class="col-sm mt-3 mt-md-0"> <figure> <video src="/assets/video/random_map.mp4" class="img-fluid rounded z-depth-1" width="auto" height="auto" autoplay="" controls=""/> </figure> </div> </div> <div class="caption"> A simple, elegant caption looks good between video rows, after each row, or doesn't have to be there at all. </div> <p>Simulate obstacle restriction method using <a href="https://cyberbotics.com/">Webots</a>. Check <a href="https://github.com/trandangtrungduc/ObstacleAvoiding-GraspingRobot">here</a> for details.</p> <div class="col-sm mt-3 mt-md-0"> <figure> <video src="/assets/video/ORM_3D_1.mp4" class="img-fluid rounded z-depth-1" width="auto" height="auto" autoplay="" controls=""/> </figure> </div> <div class="col-sm mt-3 mt-md-0"> <figure> <video src="/assets/video/ORM_3D_2.mp4" class="img-fluid rounded z-depth-1" width="auto" height="auto" autoplay="" controls=""/> </figure> </div> <p>Check <a href="https://github.com/trandangtrungduc/NeuralNetworkforMobileRobot">here</a> for details.</p>]]></content><author><name></name></author><category term="personal-project"/><category term="personal"/><summary type="html"><![CDATA[simulation and experimental videos]]></summary></entry><entry><title type="html">3DoF Arm Robot Simulation</title><link href="https://trandangtrungduc.github.io/blog/2020/arm-robot/" rel="alternate" type="text/html" title="3DoF Arm Robot Simulation"/><published>2020-08-16T00:00:00+00:00</published><updated>2020-08-16T00:00:00+00:00</updated><id>https://trandangtrungduc.github.io/blog/2020/arm-robot</id><content type="html" xml:base="https://trandangtrungduc.github.io/blog/2020/arm-robot/"><![CDATA[<p>Simulate arm robot using <strong>Solidworks</strong> &amp; <strong>Matlab</strong>. Check <a href="https://github.com/trandangtrungduc/ArmRobot3DOF">here</a> for details.</p> <div class="col-sm mt-3 mt-md-0 d-flex justify-content-center"> <figure> <video src="/assets/video/writing_control.mp4" class="img-fluid rounded z-depth-1" width="auto" height="auto" autoplay="" controls=""/> </figure> </div> <div class="col-sm mt-3 mt-md-0 d-flex justify-content-center"> <figure> <video src="/assets/video/straight_line_control.mp4" class="img-fluid rounded z-depth-1" width="auto" height="auto" autoplay="" controls=""/> </figure> </div> <p>Simulate grasping robot using Solidworks &amp; Matlab. Check <a href="https://github.com/trandangtrungduc/ObstacleAvoiding-GraspingRobot">here</a> for details.</p> <div class="col-sm mt-3 mt-md-0 d-flex justify-content-center"> <figure> <video src="/assets/video/grasping_simulation.mp4" class="img-fluid rounded z-depth-1" width="auto" height="auto" autoplay="" controls=""/> </figure> </div>]]></content><author><name></name></author><category term="personal-project"/><category term="personal"/><summary type="html"><![CDATA[simulation videos]]></summary></entry></feed>